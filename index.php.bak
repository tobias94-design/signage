            <div style="color:var(--sg-muted);font-size:12px;text-align:center;padding:20px 0;">Nessun dispositivo</div>
        <?php else: foreach($lane_disp as $ld):
            $layout_key = $ld['layout'] ?? 'standard';
            $cls = $layouts[$layout_key] ?? '.sbg2';
            $cls = ltrim($cls,'.');
