<!-- Widget JS ──────────────────────────────────────────── -->
<script>
/* Dot grid anno */
(function(){
    var dg = document.getElementById('dotgrid');
    if(!dg) return;
    var total = <?= $giorni_tot ?>, done = <?= $giorno_anno ?>;
    // mostra max 60 dot per non sfondare
    var show = Math.min(total, 60);
    var donePct = done/total;
    for(var i=0;i<show;i++){
        var d=document.createElement('div');
        d.className='dg '+(i<Math.round(show*donePct)?'dg-on':'dg-off');
        dg.appendChild(d);
    }
})();

/* Live Preview — carica dati club via fetch */
var _clubs = <?= json_encode(array_column(array_map(function($c){ return ['id'=>$c['id'],'nome'=>$c['nome']]; }, $clubs_list), null, 'id') ?: []) ?>;

function updateLivePreview(clubId) {
    var brand = document.getElementById('lp-brand');
    var clubN = document.getElementById('lp-club-name');
    var proN  = document.getElementById('lp-profilo');
    var onN   = document.getElementById('lp-online');

    if(!clubId){
        brand.textContent = 'SEGNALE TV';
        clubN.textContent = '—'; proN.textContent = '—'; onN.textContent = '—';
        return;
    }
    // Mostra nome club
    fetch('/api/club_status.php?id='+clubId)
        .then(function(r){ return r.json(); })
        .catch(function(){ return null; })
        .then(function(data){
            if(!data){ return; }
            brand.textContent = (data.nome || 'CLUB').toUpperCase().substring(0,10);
            clubN.textContent = data.nome || '—';
            proN.textContent  = data.profilo || '—';
            onN.textContent   = (data.online||0)+'/'+(data.tot||0);
        });
}

/* Auto-refresh status ogni 30s */
setTimeout(function(){ window.location.reload(); }, 30000);
</script>

