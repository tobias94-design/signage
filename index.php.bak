    $layouts = ['standard'=>'.sbg2','corsi'=>'.sbo2','sidebar'=>'.sbb2'];
    ?>
    <div class="w glass">
        <div class="wl">Programmazione
            <a href="/profili.php" class="wl-more">Modifica →</a>
        </div>
        <div class="sched">
