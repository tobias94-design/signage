<?php
require_once __DIR__ . '/includes/auth.php';
require_once __DIR__ . '/includes/db.php';
requireLogin();

$db = getDB();

/* ── Dati aggregati ─────────────────────────────────────── */
$tot_cont    = (int)$db->query("SELECT COUNT(*) FROM contenuti")->fetchColumn();
$tot_play    = (int)$db->query("SELECT COUNT(*) FROM playlist")->fetchColumn();
$tot_profili = (int)$db->query("SELECT COUNT(*) FROM profili")->fetchColumn();

$tot_disp    = (int)$db->query("SELECT COUNT(*) FROM dispositivi")->fetchColumn();
$online_disp = (int)$db->query("SELECT COUNT(*) FROM dispositivi WHERE ultimo_ping > datetime('now','-2 minutes')")->fetchColumn();
$offline_disp= $tot_disp - $online_disp;

/* Uptime % */
$uptime_pct  = $tot_disp > 0 ? round($online_disp / $tot_disp * 100) : 0;

/* Anno corrente */
$giorno_anno = (int)date('z') + 1;
$giorni_tot  = date('L') ? 366 : 365;
$anno_pct    = round($giorno_anno / $giorni_tot * 100);

/* Lista dispositivi per widget schermi */
$dispositivi = $db->query("
    SELECT d.nome, d.club,
           p.nome AS profilo_nome,
           d.ultimo_ping,
           CASE WHEN d.ultimo_ping > datetime('now','-2 minutes') THEN 'online' ELSE 'offline' END AS stato
    FROM dispositivi d
    LEFT JOIN profili p ON p.id = d.profilo_id
    ORDER BY stato DESC, d.nome ASC
    LIMIT 8
")->fetchAll(PDO::FETCH_ASSOC);

/* Club per widget preview live */
$clubs_list = [];
try {
    $clubs_list = $db->query("SELECT id, nome FROM club ORDER BY nome")->fetchAll(PDO::FETCH_ASSOC);
} catch(Exception $e) {}

/* Playlist in uso (per "in onda adesso") */
$playlist_attive = $db->query("
    SELECT p.nome, COUNT(pi.id) AS tot_items
    FROM playlist p
    LEFT JOIN playlist_items pi ON pi.playlist_id = p.id
    GROUP BY p.id
    ORDER BY tot_items DESC
    LIMIT 4
")->fetchAll(PDO::FETCH_ASSOC);

/* Prossimi eventi (profili) */
$eventi = [];
try {
    $eventi = $db->query("
        SELECT e.nome, e.orario_inizio, e.orario_fine, e.ripetizione,
               p.nome AS playlist_nome
        FROM eventi e
        LEFT JOIN playlist p ON p.id = e.playlist_id
        WHERE e.attivo = 1
        ORDER BY e.orario_inizio
        LIMIT 4
    ")->fetchAll(PDO::FETCH_ASSOC);
} catch(Exception $e) {}

/* Contenuti recenti */
$contenuti_recenti = $db->query("
    SELECT nome, tipo
    FROM contenuti
    ORDER BY id DESC
    LIMIT 5
")->fetchAll(PDO::FETCH_ASSOC);

$titolo = 'Dashboard';
require_once __DIR__ . '/includes/header.php';
